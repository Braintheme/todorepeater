# Copy this file to `.env` and fill in real values.
# `.env` is gitignored; keep secrets out of version control.
#
# Variable usage in code:
#   PROJECT_NAME  — Swagger UI title (see swagger.config.ts)
#   API_PORT      — Nest HTTP listen port (main.ts; defaults to 4000 if unset)
#   DATABASE_URL  — TypeORM connection URL (typeorm.config.ts)
#   JWT_SECRET    — signing key for access tokens (required; auth.module, jwt.strategy)
#   JWT_EXPIRE    — JWT expiry string, e.g. 90d, 12h (auth.module; default 2d if unset)
#
# The following appear in some setups but are not read by the codebase yet:
#   CLIENT_HOST, API_PREFIX

# --- Application ---
PROJECT_NAME=TodoRepeater
API_PORT=4000

# --- Database (TypeORM) ---
# Primary: PostgreSQL (Docker Compose service name `postgres`)
DATABASE_URL=postgresql://todo:password@postgres:5432/todo
# Local Postgres without Docker:
# DATABASE_URL=postgresql://todo:password@localhost:5432/todo
# Legacy MySQL (Compose still ships a `mysql` service; point here only if you switch driver back to mysql):
# DATABASE_URL=mysql://todo:password@mysql:3306/todo

# --- Auth ---
JWT_EXPIRE=90d
JWT_SECRET=replace-with-a-long-random-secret

# --- Optional / not wired in code yet ---
CLIENT_HOST=http://localhost
API_PREFIX=api
