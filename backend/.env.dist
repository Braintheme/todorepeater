# Copy this file to `.env` and fill in real values.

# --- Application ---
PROJECT_NAME=TodoRepeater
API_PORT=4000

# --- Database (TypeORM) ---
DATABASE_URL=mysql://todo:password@mysql:3306/todo

# --- Auth ---
JWT_EXPIRE=90d
JWT_SECRET=replace-with-a-long-random-secret

# --- Optional / not wired in code yet ---
CLIENT_HOST=http://localhost
API_PREFIX=api
